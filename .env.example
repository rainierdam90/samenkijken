# ---- Admin dashboard ----
# Strong password to view live counts + monitor chat at /admin
ADMIN_PASSWORD=change-me-to-something-long

# ---- Your own TURN (coturn) ----
# Shared secret, must match coturn's "static-auth-secret"
TURN_SECRET=
# Comma-separated TURN URLs (point at YOUR coturn host)
# e.g. turn:turn.watchmovietogether.com:3478,turns:turn.watchmovietogether.com:5349
TURN_URLS=
# Credential lifetime in seconds (default 3600 = 1h, used only with TURN_SECRET)
TURN_TTL=3600

# --- OR: managed TURN with STATIC credentials (Metered/Twilio/etc.) ---
# Use these INSTEAD of TURN_SECRET. Set TURN_URLS to the provider's turn: URLs.
TURN_USERNAME=
TURN_CREDENTIAL=

# ---- SECOND TURN provider (reserve, RECOMMENDED) ----
# A single TURN server cannot relay between two of its OWN relay addresses, so when TWO people
# are both behind a VPN / symmetric NAT at the same time, their call fails. A reserve relay on a
# DIFFERENT host/IP fixes that. Use any provider with a different IP than your primary coturn
# (e.g. Metered free tier, Cloudflare TURN, or a second coturn box). Leave blank to disable.
# Static-credential provider (easiest — e.g. Metered dashboard):
TURN2_URLS=
TURN2_USERNAME=
TURN2_CREDENTIAL=
# OR a second coturn with use-auth-secret (HMAC):
TURN2_SECRET=
TURN2_TTL=3600

# ---- Room limits ----
MAX_ROOM=8
CHAT_KEEP=300

# PORT is provided by the host (Render/Railway/Fly). Locally defaults to 8080.

# ---- YouTube search (optional) ----
# YouTube Data API v3 key. Stays server-side (browser never sees it).
YT_API_KEY=

# ---- Remote MKV / opaque direct-video streaming ----
# Optional system binary; when blank the bundled ffmpeg-static dependency is used.
FFMPEG_PATH=
# Set a stable value when running more than one Node instance.
MKV_TOKEN_SECRET=
MKV_TOKEN_TTL=300
MKV_MAX_STREAMS=4
MKV_MAX_STREAMS_PER_IP=2
MKV_PRESET=veryfast
# Blank deliberately permits every PUBLIC host. Set only if you want to restrict sources.
MKV_ALLOWED_HOSTS=
MKV_ALLOWED_PORTS=80,443
# Keep 0 in production. Private sources require both 1 and an explicit MKV_ALLOWED_HOSTS entry.
MKV_ALLOW_PRIVATE=0
